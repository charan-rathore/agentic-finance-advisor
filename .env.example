# Application
APP_NAME=finance-advisor
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Security (generate a strong secret for production)
SECRET_KEY=change-me-in-production

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://finance:finance@localhost:5432/finance_advisor

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=finance-advisor-agents
KAFKA_TOPIC_AGENT_EVENTS=agent.events
KAFKA_TOPIC_TRANSACTIONS=finance.transactions

# Gemini (Google AI Studio — free tier key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# RAG / ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=finance_knowledge
# Use persistent path when running Chroma embedded (optional)
CHROMA_PERSIST_DIR=./data/chroma

# Streamlit → FastAPI bridge
FASTAPI_BASE_URL=http://localhost:8000

# CORS (comma-separated; use * only for quick local experiments)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Feature flags
ENABLE_FRAUD_DETECTION=true
ENABLE_NEWS_SENTIMENT=true
