GEMINI_API_KEY=YOUR_FREE_KEY_FROM_AISTUDIO_GOOGLE_COM
GEMINI_MODEL=gemini-1.5-flash
YFINANCE_SYMBOLS=NVDA,AAPL,GOOGL,MSFT,AMZN,TSM,META,AVGO,TSLA,BRK.B,JNJ,JPM,V,UNH,PG,HD,MA
NEWS_RSS_FEEDS=https://feeds.finance.yahoo.com/rss/2.0/headline
SQLITE_PATH=./data/finance.db
WIKI_DIR=./data/wiki
WIKI_INGEST_EVERY_N_ARTICLES=5
WIKI_LINT_INTERVAL_HOURS=6
INGEST_INTERVAL_SECONDS=300
ANALYSIS_INTERVAL_SECONDS=600
GEMINI_RETRY_MAX=5
GEMINI_RETRY_BACKOFF_BASE=2
LOG_LEVEL=INFO

# SEC EDGAR API (free, no key needed)
SEC_USER_AGENT=Personal Finance Advisor your-email@example.com
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
