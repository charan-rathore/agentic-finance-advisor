GEMINI_API_KEY=YOUR_FREE_KEY_FROM_AISTUDIO_GOOGLE_COM
GEMINI_MODEL=gemini-2.5-flash
YFINANCE_SYMBOLS=NVDA,AAPL,GOOGL,MSFT,AMZN,TSM,META,AVGO,TSLA,BRK.B,JNJ,JPM,V,UNH,PG,HD,MA
# Leave blank to auto-build Google News RSS per symbol (the Yahoo default feed is dead).
NEWS_RSS_FEEDS=
SQLITE_PATH=./data/finance.db
WIKI_DIR=./data/wiki
WIKI_INGEST_EVERY_N_ARTICLES=5
WIKI_LINT_INTERVAL_HOURS=6
INGEST_INTERVAL_SECONDS=300
ANALYSIS_INTERVAL_SECONDS=600
GEMINI_RETRY_MAX=5
GEMINI_RETRY_BACKOFF_BASE=2
LOG_LEVEL=INFO

# SEC EDGAR API (free, no key needed)
SEC_USER_AGENT=Personal Finance Advisor your-email@example.com
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Macro indicators — free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_free_key_from_fred_stlouisfed_org

# Quotes + fundamentals — free tier 25 req/day: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_free_alpha_vantage_key

# Live quotes + per-company news — free tier 60 req/min: https://finnhub.io/dashboard
FINNHUB_API_KEY=your_free_finnhub_key

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FinanceBot/1.0

SEC_FILING_TYPES=8-K,10-Q

# Fetch cadences
SEC_FETCH_INTERVAL_HOURS=24
MACRO_FETCH_INTERVAL_HOURS=24
ALPHA_VANTAGE_FETCH_INTERVAL_HOURS=24
FINNHUB_FETCH_INTERVAL_HOURS=1

WIKI_LINT_STALE_HOURS_NEWS=12
WIKI_LINT_STALE_HOURS_PRICE=6
WIKI_LINT_STALE_HOURS_SEC=168
WIKI_LINT_STALE_HOURS_MACRO=72
